<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="@string/child_auto_register_title"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/child_auto_register_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- Code card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="#CC11182B"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="#804C8DFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/send_code_to_parent"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <!-- 6-digit code display -->
                <TextView
                    android:id="@+id/tv_connection_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.4"
                    android:text="000000"
                    android:textColor="@color/secondary"
                    android:textSize="52sp"
                    android:textStyle="bold" />

                <!-- Cloud registration status -->
                <TextView
                    android:id="@+id/tv_cloud_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/child_registering"
                    android:textColor="@color/neon_magenta"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Stream status -->
                <TextView
                    android:id="@+id/tv_stream_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/child_stream_starting"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <!-- Copy button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_copy_code"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:text="@string/copy_code"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    app:backgroundTint="@color/primary" />

                <!-- Regenerate button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_regenerate_code"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/generate_new_code"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    app:strokeColor="@color/secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Info card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#CC0D1A28"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#4037E5FF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/child_info_header"
                    android:textColor="@color/neon_blue"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/child_info_body"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
