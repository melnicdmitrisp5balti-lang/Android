<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo / Icon area -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="🔐"
            android:textSize="56sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/parent_code_input_title"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/parent_code_input_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- Code input card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="#CC11182B"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="#804C8DFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="28dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/enter_6_digit_code"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <!-- 6 individual digit boxes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/et_digit1"
                        style="@style/Widget.CodeDigitBox"
                        android:layout_width="44dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="6dp" />

                    <EditText
                        android:id="@+id/et_digit2"
                        style="@style/Widget.CodeDigitBox"
                        android:layout_width="44dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="6dp" />

                    <EditText
                        android:id="@+id/et_digit3"
                        style="@style/Widget.CodeDigitBox"
                        android:layout_width="44dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="12dp" />

                    <EditText
                        android:id="@+id/et_digit4"
                        style="@style/Widget.CodeDigitBox"
                        android:layout_width="44dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="6dp" />

                    <EditText
                        android:id="@+id/et_digit5"
                        style="@style/Widget.CodeDigitBox"
                        android:layout_width="44dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="6dp" />

                    <EditText
                        android:id="@+id/et_digit6"
                        style="@style/Widget.CodeDigitBox"
                        android:layout_width="44dp"
                        android:layout_height="56dp" />

                </LinearLayout>

                <!-- Status text -->
                <TextView
                    android:id="@+id/tv_connection_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="@string/enter_6_digit_code"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <!-- Connect button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_connect"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:text="@string/connect"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="12dp" />

                <!-- Clear button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_code"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/clear_code"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Hint card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#CC0D1A28"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#4037E5FF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/parent_code_hint_header"
                    android:textColor="@color/neon_blue"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/connect_dialog_cloud_hint"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
